# Holter Environment Variables Template
# Copy this file to .env and adjust as needed.

# ── Database (dev/test) ───────────────────────────────────────────────────────
DB_NAME=holter_dev
DB_USER=postgres
DB_PASS=postgres
DB_HOST=db

# ── Database (production) ─────────────────────────────────────────────────────
# DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
# POOL_SIZE=10
# ECTO_IPV6=false

# ── Phoenix ───────────────────────────────────────────────────────────────────
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE= # Generate with: mix phx.gen.secret
# PHX_SERVER=true  # Set to enable the HTTP server on release start

# ── Alert emails (monitoring notifications) ───────────────────────────────────
DELIVERY_ALERT_FROM_EMAIL=noreply@alerts.holter.dev
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=

# ── Info emails (verification, transactional) ─────────────────────────────────
INFO_FROM_EMAIL=noreply@holter.dev
INFO_SMTP_HOST=
INFO_SMTP_PORT=587
INFO_SMTP_USERNAME=
INFO_SMTP_PASSWORD=

# ── Background jobs ───────────────────────────────────────────────────────────
# METRICS_CRON_SCHEDULE="0 7 * * *"  # Default: daily at 07:00 UTC

# ── Observability (optional) ──────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Clustering (optional) ─────────────────────────────────────────────────────
# DNS_CLUSTER_QUERY=
