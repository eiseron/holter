<div class="h-workspace-layout">
  <.live_component
    module={HolterWeb.Components.WorkspaceSidebarLive}
    id="workspace-sidebar"
    workspace={@workspace}
    current_view={@socket.view}
  />
  <main class="h-workspace-main">
    <.flash_group flash={@flash} />
    {@inner_content}
  </main>
</div>
