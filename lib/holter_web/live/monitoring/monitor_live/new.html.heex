<main class="h-container">
  <section class="h-content-wrapper" style="max-width: 64rem;">
    <.header>
      {gettext("Create a new Monitor")}
      <:subtitle>
        {gettext("Configure technical details, security rules, and intervals.")}
      </:subtitle>
      <:actions>
        <.button navigate={~p"/monitoring/dashboard"} variant="secondary" size="sm">
          {gettext("Back to Dashboard")}
        </.button>
      </:actions>
    </.header>

    <.form
      for={@form}
      id="monitor-form"
      phx-change="validate"
      phx-submit="save"
      class="mt-12 space-y-12"
    >
      <fieldset class="h-card">
        <header class="h-card-header pb-4 mb-4 border-b border-ghost">
          <h3 class="h-card-title">{gettext("Technical Configuration")}</h3>
        </header>

        <div class="h-card-body space-y-8">
          <div class="h-grid h-grid-3">
            <div class="md:col-span-2 lg:col-span-1">
              <.input
                field={@form[:url]}
                type="url"
                label={gettext("URL")}
                placeholder="https://example.com.br"
                help={gettext("The target endpoint to be monitored (HTTPS recommended).")}
                required
              />
            </div>

            <.input
              field={@form[:method]}
              type="select"
              label={gettext("Method")}
              options={["GET", "POST", "HEAD", "PUT", "PATCH", "DELETE", "OPTIONS"]}
              required
            />

            <.input
              field={@form[:interval_seconds]}
              type="select"
              label={gettext("Check Interval")}
              help={gettext("How often the audit should be performed.")}
              options={[
                {gettext("1 Minute"), 60},
                {gettext("5 Minutes"), 300},
                {gettext("10 Minutes"), 600}
              ]}
              required
            />
          </div>

          <div class="h-grid h-grid-3 items-start">
            <.input
              field={@form[:timeout_seconds]}
              type="number"
              label={gettext("Timeout (Seconds)")}
              required
            />

            <div class="h-col-span-2">
              <p class="text-xs text-secondary mt-1 max-w-sm">
                {gettext("Maximum wait time for a response before marking the request as failed.")}
              </p>
            </div>
          </div>

          <div class="h-grid h-grid-2">
            <.input
              field={@form[:raw_headers]}
              type="textarea"
              label={gettext("HTTP Headers (JSON)")}
              placeholder='{"Authorization": "Bearer token"}'
              rows="3"
            />

            <.input
              field={@form[:body]}
              type="textarea"
              label={gettext("Request Body (JSON)")}
              placeholder='{"key": "value"}'
              rows="3"
            />
          </div>
        </div>
      </fieldset>

      <fieldset class="h-card">
        <header class="h-card-header pb-4 mb-4 border-b border-ghost">
          <h3 class="h-card-title">{gettext("Integrity and Validation")}</h3>
        </header>

        <div class="h-card-body space-y-8">
          <div class="h-grid h-grid-3">
            <.input
              field={@form[:raw_keyword_positive]}
              type="text"
              label={gettext("Must Contain (Keywords)")}
              placeholder={gettext("Ex: Success, Brand Name")}
            />
            <.input
              field={@form[:raw_keyword_negative]}
              type="text"
              label={gettext("Must Not Contain")}
              placeholder={gettext("Ex: error, failure, hacked")}
            />
            <div class="h-grid-center">
              <.input
                field={@form[:ssl_ignore]}
                type="checkbox"
                label={gettext("Ignore SSL Certificate Errors")}
              />
            </div>
          </div>
        </div>
      </fieldset>

      <footer class="h-form-actions">
        <.button
          type="submit"
          phx-disable-with={gettext("Saving...")}
          variant="primary"
          size="lg"
        >
          <.icon name="hero-plus" class="icon-sm" />
          {gettext("Create Monitor")}
        </.button>

        <.button navigate={~p"/monitoring/dashboard"} variant="secondary" size="lg">
          {gettext("Cancel")}
        </.button>
      </footer>
    </.form>
  </section>
</main>
